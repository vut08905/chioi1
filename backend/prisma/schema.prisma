generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model admin_audit_logs {
  log_id       Int       @id @default(autoincrement())
  admin_id     Int
  action       String    @db.VarChar(255)
  target_table String?   @db.VarChar(50)
  target_id    Int?
  old_data     Json?
  new_data     Json?
  ip_address   String?   @db.VarChar(45)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  admins       admins    @relation(fields: [admin_id], references: [admin_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model admins {
  admin_id            Int                   @id
  department          String?               @db.VarChar(100)
  access_level        String?               @default("SUPPORT") @db.VarChar(20)
  admin_audit_logs    admin_audit_logs[]
  users               users                 @relation(fields: [admin_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  order_interventions order_interventions[]
  support_tickets     support_tickets[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model customer_packages {
  customer_package_id Int             @id @default(autoincrement())
  customer_id         Int
  package_id          Int
  start_date          DateTime        @db.Date
  end_date            DateTime        @db.Date
  status              String?         @default("ACTIVE") @db.VarChar(20)
  created_at          DateTime?       @default(now()) @db.Timestamp(6)
  customers           customers       @relation(fields: [customer_id], references: [customer_id], onDelete: NoAction, onUpdate: NoAction)
  family_packages     family_packages @relation(fields: [package_id], references: [package_id], onDelete: NoAction, onUpdate: NoAction)
}

model customers {
  customer_id       Int                 @id
  default_address   String?
  loyalty_points    Int?                @default(0)
  customer_packages customer_packages[]
  users             users               @relation(fields: [customer_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  orders            orders[]
  reviews           reviews[]
}

model family_packages {
  package_id        Int                 @id @default(autoincrement())
  name              String              @db.VarChar(100)
  description       String?
  price             Decimal             @db.Decimal(12, 2)
  duration_days     Int?                @default(30)
  is_active         Boolean?            @default(true)
  customer_packages customer_packages[]
}

model messages {
  message_id                        Int       @id @default(autoincrement())
  order_id                          Int?
  sender_id                         Int
  receiver_id                       Int
  content                           String
  is_read                           Boolean?  @default(false)
  created_at                        DateTime? @default(now()) @db.Timestamp(6)
  orders                            orders?   @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: NoAction)
  users_messages_receiver_idTousers users     @relation("messages_receiver_idTousers", fields: [receiver_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  users_messages_sender_idTousers   users     @relation("messages_sender_idTousers", fields: [sender_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model notifications {
  notification_id Int       @id @default(autoincrement())
  user_id         Int
  title           String    @db.VarChar(255)
  content         String
  is_read         Boolean?  @default(false)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  users           users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model otp_codes {
  id            Int       @id @default(autoincrement())
  user_id       Int
  phone         String    @db.VarChar(20)
  otp_code      String    @db.VarChar(8)
  purpose       String    @default("RESET_PASSWORD") @db.VarChar(30)
  attempts      Int       @default(0)
  max_attempts  Int       @default(5)
  expires_at    DateTime  @db.Timestamp(6)
  used_at       DateTime? @db.Timestamp(6)
  created_at    DateTime  @default(now()) @db.Timestamp(6)

  user          users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([phone])
  @@index([expires_at])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_interventions {
  intervention_id Int       @id @default(autoincrement())
  order_id        Int
  admin_id        Int
  action_type     String    @db.VarChar(20)
  reason          String?
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  admins          admins    @relation(fields: [admin_id], references: [admin_id], onDelete: NoAction, onUpdate: NoAction)
  orders          orders    @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: NoAction)
}

model order_status_history {
  history_id       Int                      @id @default(autoincrement())
  order_id         Int
  status           String                   @db.VarChar(20)
  location_at_time Unsupported("geometry")?
  created_at       DateTime?                @default(now()) @db.Timestamp(6)
  orders           orders                   @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model orders {
  order_id             Int                      @id @default(autoincrement())
  order_code           String                   @unique @db.VarChar(50)
  customer_id          Int
  tasker_id            Int?
  service_id           Int
  voucher_id           Int?
  status               String?                  @default("PENDING") @db.VarChar(20)
  scheduled_time       DateTime                 @db.Timestamp(6)
  address              String
  location             Unsupported("geometry")?
  total_price          Decimal                  @db.Decimal(12, 2)
  discount_amount      Decimal?                 @default(0) @db.Decimal(12, 2)
  tasker_earnings      Decimal                  @db.Decimal(12, 2)
  platform_fee         Decimal                  @db.Decimal(12, 2)
  payment_method       String?                  @default("CASH") @db.VarChar(20)
  payment_status       String?                  @default("UNPAID") @db.VarChar(20)
  notes                String?
  cancel_reason        String?
  created_at           DateTime?                @default(now()) @db.Timestamp(6)
  updated_at           DateTime?                @default(now()) @db.Timestamp(6)
  messages             messages[]
  order_interventions  order_interventions[]
  order_status_history order_status_history[]
  customers            customers                @relation(fields: [customer_id], references: [customer_id], onDelete: NoAction, onUpdate: NoAction)
  services             services                 @relation(fields: [service_id], references: [service_id], onDelete: NoAction, onUpdate: NoAction)
  taskers              taskers?                 @relation(fields: [tasker_id], references: [tasker_id], onDelete: NoAction, onUpdate: NoAction)
  vouchers             vouchers?                @relation(fields: [voucher_id], references: [voucher_id], onDelete: NoAction, onUpdate: NoAction)
  reviews              reviews?
  support_tickets      support_tickets[]
  transactions         transactions[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  review_id   Int       @id @default(autoincrement())
  order_id    Int       @unique
  customer_id Int
  tasker_id   Int
  rating      Int
  comment     String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  customers   customers @relation(fields: [customer_id], references: [customer_id], onDelete: NoAction, onUpdate: NoAction)
  orders      orders    @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: NoAction)
  taskers     taskers   @relation(fields: [tasker_id], references: [tasker_id], onDelete: NoAction, onUpdate: NoAction)
}

model services {
  service_id      Int               @id @default(autoincrement())
  name            String            @db.VarChar(100)
  description     String?
  base_price      Decimal           @db.Decimal(12, 2)
  icon_url        String?           @db.VarChar(255)
  is_active       Boolean?          @default(true)
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  orders          orders[]
  tasker_services tasker_services[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model support_tickets {
  ticket_id   Int       @id @default(autoincrement())
  ticket_code String    @unique @db.VarChar(50)
  user_id     Int
  admin_id    Int?
  order_id    Int?
  subject     String    @db.VarChar(255)
  description String
  status      String?   @default("OPEN") @db.VarChar(20)
  priority    String?   @default("MEDIUM") @db.VarChar(20)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  admins      admins?   @relation(fields: [admin_id], references: [admin_id], onDelete: NoAction, onUpdate: NoAction)
  orders      orders?   @relation(fields: [order_id], references: [order_id], onDelete: NoAction, onUpdate: NoAction)
  users       users     @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model tasker_services {
  tasker_id  Int
  service_id Int
  status     String?  @default("PENDING_APPROVAL") @db.VarChar(20)
  services   services @relation(fields: [service_id], references: [service_id], onDelete: Cascade, onUpdate: NoAction)
  taskers    taskers  @relation(fields: [tasker_id], references: [tasker_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([tasker_id, service_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model taskers {
  tasker_id        Int                      @id
  bio              String?
  address          String?
  kyc_status       String?                  @default("UNVERIFIED") @db.VarChar(20)
  average_rating   Decimal?                 @default(0.00) @db.Decimal(3, 2)
  total_jobs       Int?                     @default(0)
  is_online        Boolean?                 @default(false)
  last_heartbeat   DateTime?                @db.Timestamp(6)
  current_location Unsupported("geometry")?
  orders           orders[]
  reviews          reviews[]
  tasker_services  tasker_services[]
  users            users                    @relation(fields: [tasker_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model transactions {
  transaction_id   Int       @id @default(autoincrement())
  transaction_code String    @unique @db.VarChar(50)
  wallet_id        Int
  amount           Decimal   @db.Decimal(12, 2)
  type             String    @db.VarChar(20)
  status           String?   @default("PENDING") @db.VarChar(20)
  order_id         Int?
  description      String?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  orders           orders?   @relation(fields: [order_id], references: [order_id], onDelete: NoAction, onUpdate: NoAction)
  wallets          wallets   @relation(fields: [wallet_id], references: [wallet_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  user_id                              Int               @id @default(autoincrement())
  phone                                String            @unique @db.VarChar(20)
  password_hash                        String            @db.VarChar(255)
  full_name                            String            @db.VarChar(100)
  email                                String?           @db.VarChar(255)
  gender                               String?           @db.VarChar(10)
  avatar_url                           String?           @db.VarChar(255)
  role                                 String            @db.VarChar(20)
  status                               String?           @default("ACTIVE") @db.VarChar(20)
  created_at                           DateTime?         @default(now()) @db.Timestamp(6)
  updated_at                           DateTime?         @default(now()) @db.Timestamp(6)
  admins                               admins?
  customers                            customers?
  messages_messages_receiver_idTousers messages[]        @relation("messages_receiver_idTousers")
  messages_messages_sender_idTousers   messages[]        @relation("messages_sender_idTousers")
  notifications                        notifications[]
  support_tickets                      support_tickets[]
  taskers                              taskers?
  wallets                              wallets?
  otp_codes                            otp_codes[]
}

model vouchers {
  voucher_id      Int       @id @default(autoincrement())
  code            String    @unique @db.VarChar(50)
  discount_amount Decimal   @db.Decimal(12, 2)
  conditions      String?
  valid_from      DateTime? @db.Timestamp(6)
  valid_until     DateTime? @db.Timestamp(6)
  is_active       Boolean?  @default(true)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  orders          orders[]
}

model wallets {
  wallet_id    Int            @id @default(autoincrement())
  user_id      Int            @unique
  balance      Decimal?       @default(0.00) @db.Decimal(15, 2)
  updated_at   DateTime?      @default(now()) @db.Timestamp(6)
  transactions transactions[]
  users        users          @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}
