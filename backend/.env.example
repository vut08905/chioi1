# ==========================================================
# CHỊ ƠI! Backend Environment Variables
# Copy file này thành .env và điền giá trị thật.
# KHÔNG commit .env lên Git.
# ==========================================================

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chioi"

# --- JWT ---
# Production: dùng chuỗi random ≥ 64 ký tự (mã openssl rand -hex 64)
JWT_SECRET="super-secret-key-123"

# --- Server ---
PORT=3000

# ==========================================================
# Tích hợp ngoài (chưa kết nối — đang dùng Mock provider)
# ==========================================================

# --- SMS Provider ---
# Giá trị: mock | fpt | vnpt | speedsms | esms
SMS_PROVIDER=mock
SMS_FPT_API_KEY=
SMS_FPT_API_SECRET=
SMS_FPT_BRAND_NAME=ChiOi
SMS_VNPT_API_KEY=
SMS_VNPT_BRAND_NAME=ChiOi

# --- KYC Provider ---
# Giá trị: mock | fpt_ai | vnpt_ekyc
KYC_PROVIDER=mock
KYC_FPT_API_KEY=
KYC_FPT_API_SECRET=

# --- Payment / Banking Webhook ---
# Giá trị: mock | casso | sepay
PAYMENT_PROVIDER=mock
PAYMENT_BANK_ACCOUNT=
PAYMENT_BANK_NAME=
PAYMENT_CASSO_API_KEY=
PAYMENT_CASSO_WEBHOOK_SECRET=
PAYMENT_SEPAY_API_KEY=
PAYMENT_SEPAY_WEBHOOK_SECRET=
